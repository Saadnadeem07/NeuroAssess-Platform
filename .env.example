# ---------------------------------------------------------------------------
# NeuroAssess (Next.js) — environment variables
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# App URL (used in password-reset / approval emails)
APP_URL=http://localhost:3000

# --- Database --------------------------------------------------------------
# MongoDB connection string (Atlas or local).
MONGODB_URI=mongodb://127.0.0.1:27017/neuroassess

# --- JWT secrets -----------------------------------------------------------
# Generate strong values, e.g.  openssl rand -hex 48
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# --- Email (SMTP via Nodemailer) -------------------------------------------
# OTP, password-reset and psychiatrist approval emails go through this.
# In development, if these are unset the app logs the OTP to the server
# console instead of sending a real email (see src/lib/email.ts).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# --- Google OAuth ("Sign in with Google") ----------------------------------
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorised redirect URI must be exactly:  ${APP_URL}/api/auth/google/callback
# Leave these blank to hide/disable the Google button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI handwriting analysis -----------------------------------------------
# The detection model is mocked in this port (see src/lib/ai.ts).
# Set MOCK_AI=false and provide a real endpoint to wire a live model later.
MOCK_AI=true
HANDWRITING_API_URL=
HANDWRITING_API_KEY=

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
